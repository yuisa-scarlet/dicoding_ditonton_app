    "version": "0.2.0",
    "configurations": [
        {
            "name": "flutter_dicoding_expert",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define=TMDB_API_KEY=PUT_YOUR_TMDB_API_KEY_HERE"
            ]
        },
        {
            "name": "flutter_dicoding_expert (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "toolArgs": [
                "--dart-define=TMDB_API_KEY=PUT_YOUR_TMDB_API_KEY_HERE"
            ]
        },
        {
            "name": "flutter_dicoding_expert (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "toolArgs": [
                "--dart-define=TMDB_API_KEY=PUT_YOUR_TMDB_API_KEY_HERE"
            ]
        }
    ]
}
